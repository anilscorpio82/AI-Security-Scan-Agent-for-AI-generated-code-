# Copy this file to `.env` before running locally
# Only ONE LLM provider key is needed — the scanner auto-detects which to use.

# ── Option 1: Anthropic Claude (Recommended) ─────────────────────────────────
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude model to use (optional — defaults to claude-3-5-haiku-20241022)
# Other options: claude-opus-4-5, claude-sonnet-4-5, claude-3-5-sonnet-20241022
# CLAUDE_MODEL=claude-3-5-haiku-20241022

# ── Option 2: Google Gemini ───────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
# GOOGLE_API_KEY=your_gemini_api_key_here

# Gemini model to use (optional — defaults to gemini-1.5-flash)
# GEMINI_MODEL=gemini-1.5-flash

# ── Scan Configuration ────────────────────────────────────────────────────────
# Path to the repository/folder to scan (defaults to ./tests/vulnerable_repo/)
# SCAN_TARGET=./your_project_folder/

# ── FastAPI Backend ───────────────────────────────────────────────────────────
BACKEND_PORT=8000

# ── Nginx Frontend ────────────────────────────────────────────────────────────
FRONTEND_PORT=8080
